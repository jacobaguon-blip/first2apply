{
  "name": "first2apply-server-probe",
  "version": "0.0.1",
  "private": true,
  "description": "Headless server-side probe (Electron main-only) for running first2apply on a Pi/server.",
  "main": "dist/main.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "lint": "echo 'lint: noop (serverProbe scaffold)'",
    "test": "echo 'test: noop (serverProbe scaffold)'",
    "start": "electron dist/main.js",
    "selftest": "electron dist/main.js --selftest",
    "dry-run": "electron dist/main.js --dry-run",
    "scan-once": "electron dist/main.js --scan-once"
  },
  "dependencies": {
    "@first2apply/core": "workspace:*",
    "@first2apply/scraper": "workspace:*",
    "@supabase/supabase-js": "^2.45.4",
    "exponential-backoff": "^3.1.1"
  },
  "devDependencies": {
    "electron": "39.0.0",
    "typescript": "^5.6.3"
  }
}
