{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "jsx": "preserve",
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": false,
    "lib": ["dom", "ES2022"]
  },
  "include": ["app/**/*", "src/**/*", "lib/**/*"],
  "exclude": ["node_modules"]
}
