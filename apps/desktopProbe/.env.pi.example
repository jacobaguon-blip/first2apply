# Copy to .env.pi on the Raspberry Pi and fill in.

# Supabase Cloud — get these from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=YOUR_ANON_KEY

# App bundle id (any string; used by Electron for userData path).
APP_BUNDLE_ID=ro.beastx.first2apply.pi

# Optional telemetry — leave blank to disable.
MEZMO_API_KEY=
AMPLITUDE_API_KEY=

# Pushover (https://pushover.net) — when both are set the probe sends push alerts
# regardless of the in-app Pushover toggle. This lets you configure the Pi
# without interactive UI access.
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# Optional Xvfb virtual screen size.
XVFB_SCREEN=1280x720x24
