# first2apply Pi env — placeholders only. Real values written by user on Pi (chmod 600).
# DO NOT COMMIT REAL VALUES.

# Cloud Supabase service-role key (used by serverProbe + pg_dump)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me

# pg_dump source (cloud Supabase Postgres URL with service-role)
PG_DUMP_URL=postgres://postgres:replace@db.YOUR_PROJECT.supabase.co:5432/postgres

# Pushover (mock during dev; real values from user when ready).
# F2A_PUSHOVER_MOCK=1 short-circuits sendPushover() to a no-op (apps/desktopProbe/src/server/pushover.ts:78).
# In production set to 0 (or unset) so real Pushover delivery happens.
PUSHOVER_APP_TOKEN=replace-me
PUSHOVER_USER_KEY=replace-me
F2A_PUSHOVER_MOCK=0

# OpenAI
OPENAI_API_KEY=replace-me
F2A_AI_MOCK=0

# Approval token signing (Item 11)
APPROVAL_HMAC_SECRET=replace-me-with-strong-random

# Owner user id — serverProbe runs without auth, so this stands in for the
# authenticated user the scraper would otherwise resolve via supabase.auth.
# Set to the Supabase auth.users.id of the account whose links are being scanned.
F2A_OWNER_USER_ID=replace-me-with-uuid

# JobScanner cron rule (one of the seven AVAILABLE_CRON_RULES values).
F2A_CRON_RULE=0 * * * *

# Tee logger output to /opt/first2apply/logs/serverProbe.log in addition to stdout.
F2A_LOG_FILE=0

# Container timezone — affects journalctl log timestamps. Set to user's TZ
# so log timestamps match the desktop's frame of reference. Quiet hours code
# uses user_settings.quiet_hours_timezone separately (not this).
TZ=America/Los_Angeles
